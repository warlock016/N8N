{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "fail2ban Status",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "fail2ban_up", "legendFormat": "fail2ban" }]
    },
    {
      "type": "stat",
      "title": "Currently Banned IPs",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(fail2ban_banned_total)", "legendFormat": "Banned" }]
    },
    {
      "type": "stat",
      "title": "SSH Failures (1h)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "ssh_failed_attempts_last_hour", "legendFormat": "Failures" }]
    },
    {
      "type": "stat",
      "title": "Unique Attackers (1h)",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 15 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "ssh_unique_attackers_last_hour", "legendFormat": "Attackers" }]
    },
    {
      "type": "stat",
      "title": "Recent Bans (1h)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "fail2ban_recent_bans", "legendFormat": "Bans" }]
    },
    {
      "type": "stat",
      "title": "Recidive Banned",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "fail2ban_banned_total{jail=\"recidive\"}", "legendFormat": "Recidive" }]
    },
    {
      "type": "timeseries",
      "title": "SSH Attack Activity",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "lineWidth": 2, "pointSize": 5, "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "ssh_failed_attempts_last_hour", "legendFormat": "Failed Attempts" },
        { "expr": "ssh_unique_attackers_last_hour", "legendFormat": "Unique Attackers" },
        { "expr": "fail2ban_recent_bans", "legendFormat": "Bans (1h)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Banned IPs by Jail",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 30, "lineWidth": 2, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "fail2ban_banned_total", "legendFormat": "{{jail}}" }
      ]
    },
    {
      "type": "table",
      "title": "Currently Banned IPs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.hidden", "value": true }] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "jail", "desc": false }] },
      "transformations": [{ "id": "filterByValue", "options": { "filters": [{ "fieldName": "Value", "config": { "id": "greater", "options": { "value": 0 } } }], "type": "include", "match": "any" } }],
      "targets": [{ "expr": "fail2ban_banned_ip", "format": "table", "instant": true }]
    },
    {
      "type": "logs",
      "title": "SSH Auth Log (Live)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "options": { "showTime": true, "showLabels": false, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" },
      "targets": [{ "expr": "{job=\"auth\"} |~ \"sshd|fail2ban\"", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Failed Attempts & Bans Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2, "spanNulls": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Total Bans" }, "properties": [{ "id": "custom.axisPlacement", "value": "right" }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "fail2ban_failed_total", "legendFormat": "Failed {{jail}}" },
        { "expr": "fail2ban_bans_total", "legendFormat": "Total Bans {{jail}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Permanent Blocklist IPs",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "blocklist_ips_total", "legendFormat": "IPs" }]
    },
    {
      "type": "stat",
      "title": "Permanent Blocklist Subnets",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "blocklist_subnets_total", "legendFormat": "Subnets" }]
    },
    {
      "type": "stat",
      "title": "Last Blocklist Update",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeFromNow",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3600 }, { "color": "red", "value": 7200 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "blocklist_last_update_timestamp * 1000", "legendFormat": "Last Update" }]
    },
    {
      "type": "stat",
      "title": "Added Last Run",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "expr": "blocklist_ips_added_last_run", "legendFormat": "IPs" },
        { "expr": "blocklist_subnets_added_last_run", "legendFormat": "Subnets" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Blocklist Growth Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "lineWidth": 2, "spanNulls": true }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "blocklist_ips_total", "legendFormat": "Blocked IPs" },
        { "expr": "blocklist_subnets_total", "legendFormat": "Blocked Subnets" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["security", "fail2ban", "ssh"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Security & Intrusion Detection",
  "uid": "security-dashboard",
  "version": 1
}
